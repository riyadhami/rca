# ─── Vertex AI (Google Cloud) ─────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./key.json
VERTEX_LOCATION=us-east5
VERTEX_MODEL=claude-sonnet-4-5

# ─── Processing ───────────────────────────────────────────────────────────────
BATCH_SIZE=10
MAX_CONCURRENT=5

# ─── Frontend ─────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
